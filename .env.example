# ============================================================
# HKM Ministries CMS - Environment Variables
# ============================================================
# SECURITY: Do NOT commit sensitive values to .env files.
# Use GitHub Actions secrets for production builds.
# Use .env.local for local development (already gitignored).
# ============================================================
# VITE_ prefixed vars are bundled into the client-side code.
# Non-VITE_ vars are server-side only (CI pipelines, etc.).
# ============================================================

# --- Required: Client-safe (VITE_ prefix) ---

# Clerk publishable key (safe for browser)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase pg_graphql endpoint
VITE_SUPABASE_GRAPHQL_URL=https://<project-ref>.supabase.co/graphql/v1

# Supabase anon key (safe for browser — protected by Row Level Security)
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Optional ---

# Gemini AI key (for local dev without proxy)
VITE_AI_API_KEY=

# Gemini AI proxy URL (deploy server/gemini-proxy.js to Cloudflare Workers first)
VITE_GEMINI_PROXY_URL=https://hkm-gemini-proxy.your-domain.workers.dev

# REMOVED: VITE_SUPER_ADMIN_* vars — super admin secrets must never be in the client bundle.
# All admin authentication is handled through Clerk.
# Role elevation (Super Admin / Admin) is enforced server-side via Clerk JWT templates
# and Supabase Row Level Security policies.
# See supabase_schema.sql for the users table with role-based access.

# --- Server-side only (NOT VITE_ prefix) ---

# Clerk secret key (for server-side operations)
CLERK_SECRET_KEY=
